{
    "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
    "productName": "darox",
    "version": "0.1.0",
    "identifier": "net.solariar",
    "build": {
        "frontendDist": "../out",
        "devUrl": "http://localhost:3140",
        "beforeDevCommand": "npm run dev",
        "beforeBuildCommand": "npm run build"
    },
    "app": {
        "windows": [
            {
                "title": "darox",
                "width": 800,
                "height": 600,
                "resizable": true,
                "fullscreen": false
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": [],
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    }
}
