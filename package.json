{
  "name": "darox",
  "version": "0.0.1",
  "private": true,
  "main": "electron/dist/main.js",
  "scripts": {
    "dev": "next dev -p 3140",
    "build": "next build",
    "build:check": "NEXT_DIST_DIR=.next-check next build",
    "start": "next start -p 3140",
    "lint": "eslint .",
    "electron:compile": "tsc -p electron",
    "electron:dev": "concurrently -k -n next,electron -c blue,magenta \"npm run dev\" \"wait-on http://localhost:3140 && npm run electron:compile && cross-env ELECTRON_DEV=1 electron electron/dist/main.js\"",
    "electron:build": "next build && npm run electron:compile && electron-builder"
  },
  "dependencies": {
    "@ai-sdk/react": "3.0.99",
    "@assistant-ui/react": "^0.12.21",
    "@assistant-ui/react-ai-sdk": "^1.3.10",
    "@assistant-ui/react-markdown": "^0.12.7",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/postcss": "^4.2.1",
    "ai": "6.0.97",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^0.576.0",
    "next": "^15.5.9",
    "radix-ui": "^1.4.3",
    "react": "^18",
    "react-dom": "^18",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "streamdown": "^2.3.0",
    "tailwind-merge": "^3.0.2",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "tw-shimmer": "^0.4.9",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.3",
    "@eslint/eslintrc": "^3.3.5",
    "@types/node": "20.17.24",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.14",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "^15.0.0",
    "png2icons": "^2.0.1",
    "tailwindcss": "^4.2.1",
    "typescript": "5.8.3",
    "wait-on": "^9.0.10"
  }
